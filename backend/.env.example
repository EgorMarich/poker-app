# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=student
DB_PASSWORD=student
DB_NAME=poker_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change-me-in-production-very-long-secret
JWT_EXPIRES_IN=7d

# Telegram Bot
# Получить у @BotFather → /newbot
# В dev можно поставить "dev" — тогда валидация подписи отключена
TELEGRAM_BOT_TOKEN=dev

# AI (OpenAI or compatible)


GIGACHAT_CLIENT_ID=твой_client_id
GIGACHAT_CLIENT_SECRET=твой_client_secret
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat

# YooKassa
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key
YOOKASSA_RETURN_URL=http://localhost:3000/payment/success

# Throttle
THROTTLE_TTL=60
THROTTLE_LIMIT=100
